{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "battery", "tray"],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{name}"
    },
    "clock": {
        "format": "{:%a %d %b  %H:%M}"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "format-charging": "ΎΔπ {capacity}%"
    },
    "network": {
        "format-wifi": "ΎΘτ {essid}",
        "format-ethernet": "ΎΔΒ Connected",
        "format-disconnected": "έγι Offline"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "ΎΑο Muted",
        "format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "tray": {
        "spacing": 10
    }
}
